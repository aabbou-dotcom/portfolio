---
/**
 * pages/index.astro
 * Main portfolio page assembling all components
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Education from '../components/Education.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
import { portfolioData } from '../data/portfolio';

// Conditionally render sections based on available data
const showExperience = portfolioData.experience && portfolioData.experience.length > 0;
const showPublications = portfolioData.publications && portfolioData.publications.length > 0;
const showCertifications = portfolioData.certifications && portfolioData.certifications.length > 0;

let ExperienceComponent, CertificationsComponent, PublicationsComponent;

if (showExperience) {
  ExperienceComponent = (await import('../components/Experience.astro')).default;
}
if (showCertifications) {
  CertificationsComponent = (await import('../components/Certifications.astro')).default;
}
if (showPublications) {
  PublicationsComponent = (await import('../components/Publications.astro')).default;
}
---

<BaseLayout
  title={`${portfolioData.personal.firstName} ${portfolioData.personal.lastName} - Portfolio`}
  description={portfolioData.personal.bio}
>
  <!-- Hero Section -->
  <Hero />

  <!-- About Section -->
  <About />

  <!-- Skills Section -->
  <Skills />

  <!-- Education Section -->
  <Education />

  <!-- Experience Section (conditional) -->
  {showExperience && ExperienceComponent && <ExperienceComponent />}

  <!-- Projects Section -->
  <Projects />

  <!-- Certifications Section (conditional) -->
  {showCertifications && CertificationsComponent && <CertificationsComponent />}

  <!-- Publications Section (conditional) -->
  {showPublications && PublicationsComponent && <PublicationsComponent />}

  <!-- Contact Section -->
  <Contact />
</BaseLayout>

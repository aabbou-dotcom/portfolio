---
/**
 * Contact.astro
 * Contact form and information section
 */

import { portfolioData } from '../data/portfolio';

const { email, phone, location } = portfolioData.personal;
---

<section id="contact" data-section class="py-20 md:py-32">
  <div class="container max-w-6xl mx-auto px-4 md:px-8">
    <!-- Section Title -->
    <div class="mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Me <span class="gradient-text">Contacter</span>
      </h2>
      <p class="text-lg text-[var(--text-secondary)] max-w-2xl">
        N'hésitez pas à me contacter pour discuter de projets ou d'opportunités.
      </p>
    </div>

    <!-- Contact Grid -->
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div class="space-y-6">
        <!-- Email -->
        <div
          data-animate
          class="glass rounded-lg p-6 hover:bg-white/15 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
          style="animation-delay: 0ms;"
        >
          <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-[var(--color-primary)]/20 to-[var(--color-accent)]/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-all duration-300">
            <svg class="w-6 h-6 text-[var(--color-primary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <h4 class="font-bold mb-2">Email</h4>
          <a href={`mailto:${email}`} class="text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors">
            {email}
          </a>
        </div>

        <!-- Phone -->
        {phone && (
          <div
            data-animate
            class="glass rounded-lg p-6 hover:bg-white/15 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
            style="animation-delay: 100ms;"
          >
            <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-[var(--color-primary)]/20 to-[var(--color-accent)]/20 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[var(--color-primary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <h4 class="font-bold mb-2">Téléphone</h4>
            <a href={`tel:${phone}`} class="text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors">
              {phone}
            </a>
          </div>
        )}

        <!-- Location -->
        <div
          data-animate
          class="glass rounded-lg p-6 hover:bg-white/15 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
          style="animation-delay: 200ms;"
        >
          <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-[var(--color-primary)]/20 to-[var(--color-accent)]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[var(--color-primary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <h4 class="font-bold mb-2">Localisation</h4>
          <p class="text-[var(--text-secondary)]">{location}</p>
        </div>

        <!-- Social Links -->
        <div class="mt-8 pt-8 border-t border-[var(--color-border)]">
          <h4 class="font-bold mb-4">Réseaux Sociaux</h4>
          <div class="grid grid-cols-2 gap-3">
            {portfolioData.social.map((social, idx) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                title={social.platform}
                class="glass rounded-lg p-4 text-center hover:bg-white/20 hover:text-[var(--color-primary)] hover:-translate-y-1 transition-all duration-300"
                style={`animation-delay: ${300 + idx * 50}ms;`}
              >
                <p class="text-sm font-medium">{social.platform}</p>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div
        data-animate
        class="glass rounded-lg p-6 md:p-8"
        style="animation-delay: 100ms;"
      >
        <form id="contact-form" class="space-y-4">
          <!-- Honeypot -->
          <input type="text" name="website" style="display:none;" />

          <!-- Name -->
          <div>
            <label class="block text-xs uppercase font-semibold text-[var(--text-secondary)] mb-2">Nom</label>
            <input
              type="text"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg bg-[var(--bg-secondary)] border border-[var(--color-border)] text-[var(--text-primary)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]/50 transition-all duration-300"
              placeholder="Votre nom"
            />
          </div>

          <!-- Email -->
          <div>
            <label class="block text-xs uppercase font-semibold text-[var(--text-secondary)] mb-2">Email</label>
            <input
              type="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg bg-[var(--bg-secondary)] border border-[var(--color-border)] text-[var(--text-primary)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]/50 transition-all duration-300"
              placeholder="votre@email.com"
            />
          </div>

          <!-- Subject -->
          <div>
            <label class="block text-xs uppercase font-semibold text-[var(--text-secondary)] mb-2">Sujet</label>
            <input
              type="text"
              name="subject"
              required
              class="w-full px-4 py-3 rounded-lg bg-[var(--bg-secondary)] border border-[var(--color-border)] text-[var(--text-primary)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]/50 transition-all duration-300"
              placeholder="Sujet du message"
            />
          </div>

          <!-- Message -->
          <div>
            <label class="block text-xs uppercase font-semibold text-[var(--text-secondary)] mb-2">Message</label>
            <textarea
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-lg bg-[var(--bg-secondary)] border border-[var(--color-border)] text-[var(--text-primary)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]/50 transition-all duration-300 resize-none"
              placeholder="Votre message..."
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="submit-btn"
            class="w-full px-6 py-3 rounded-lg bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] text-white font-medium hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-2"
          >
            <span id="btn-text">Envoyer le Message</span>
            <svg id="btn-icon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
            </svg>
            <div id="btn-spinner" class="hidden w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- Toast Notification -->
<div id="contact-toast" class="fixed bottom-4 right-4 glass rounded-lg p-4 max-w-sm hidden animate-slide-up z-50">
  <div class="flex items-center gap-3">
    <div id="toast-icon"></div>
    <p id="toast-message" class="text-sm"></p>
    <button id="toast-close" class="ml-auto">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
</div>

<script is:inline>
  const form = document.getElementById('contact-form');
  const toast = document.getElementById('contact-toast');
  const toastMessage = document.getElementById('toast-message');
  const toastIcon = document.getElementById('toast-icon');
  const toastClose = document.getElementById('toast-close');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnIcon = document.getElementById('btn-icon');
  const btnSpinner = document.getElementById('btn-spinner');

  function showToast(message, isSuccess = true) {
    toastMessage.textContent = message;
    if (isSuccess) {
      toastIcon.innerHTML = '<svg class="w-6 h-6 text-[var(--color-success)]" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>';
    } else {
      toastIcon.innerHTML = '<svg class="w-6 h-6 text-[var(--color-warning)]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2m1 15h-2v-2h2v2m0-4h-2V7h2v6z"/></svg>';
    }
    toast.classList.remove('hidden');
    
    setTimeout(() => {
      toast.classList.add('hidden');
    }, 4000);
  }

  toastClose.addEventListener('click', () => {
    toast.classList.add('hidden');
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Check honeypot
    if (form.website.value) {
      console.log('Honeypot triggered');
      return;
    }

    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnIcon.classList.add('hidden');
    btnSpinner.classList.remove('hidden');

    const formData = new FormData(form);
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      subject: formData.get('subject'),
      message: formData.get('message')
    };

    try {
      const response = await fetch('https://formsubmit.co/ajax/a.abbou@esisa.as.ma', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(data)
      });

      if (response.ok) {
        showToast('Message envoyé avec succès! Merci de nous avoir contacté.', true);
        form.reset();
      } else {
        showToast('Erreur lors de l\'envoi. Veuillez réessayer.', false);
      }
    } catch (error) {
      showToast('Erreur de connexion. Veuillez réessayer.', false);
    } finally {
      submitBtn.disabled = false;
      btnText.classList.remove('hidden');
      btnIcon.classList.remove('hidden');
      btnSpinner.classList.add('hidden');
    }
  });
</script>

<style>
  @media (prefers-reduced-motion: no-preference) {
    [data-animate] {
      opacity: 0;
      animation: fadeInUp 0.6s ease-out forwards;
    }
  }
</style>

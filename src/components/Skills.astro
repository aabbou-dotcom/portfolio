---
// Skills.astro - Section Compétences
// Compétences techniques et soft avec icônes et animations

import { portfolioData } from '../data/data';
import { getIcon } from './icons';

const { technicalSkills, softSkills } = portfolioData;
---

<section id="skills" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Titre de section -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4">
        Mes <span class="bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">compétences</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Technologies maîtrisées et compétences transversales développées
      </p>
    </div>

    <!-- Compétences techniques -->
    <div class="mb-20">
      <!-- Label diviseur -->
      <div class="flex items-center justify-center mb-12 reveal">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent to-gray-600"></div>
        <span class="px-6 py-2 bg-gray-800/50 text-gray-300 text-sm font-medium rounded-full border border-gray-600/50">
          Technical Skills
        </span>
        <div class="flex-1 h-px bg-gradient-to-l from-transparent to-gray-600"></div>
      </div>

      <!-- Grille des catégories techniques -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {technicalSkills.map(category => (
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-lg p-6 hover:bg-white/10 transition-all duration-300 hover:scale-105 group reveal">
            <!-- Icône de catégorie -->
            <div class="flex items-center justify-center w-12 h-12 bg-gradient-to-br from-blue-500/20 to-purple-500/20 rounded-lg mb-4 group-hover:scale-110 transition-transform duration-200">
              <span set:html={getIcon(category.icon, 'w-6 h-6 text-blue-400')}></span>
            </div>

            <!-- Titre de catégorie -->
            <h3 class="text-xl font-semibold mb-4 text-gray-200">{category.name}</h3>

            <!-- Compteur -->
            <div class="text-sm text-gray-400 mb-4 font-mono">
              {category.skills.length} compétences
            </div>

            <!-- Pastilles de compétences -->
            <div class="flex flex-wrap gap-2">
              {category.skills.map(skill => (
                <span class="px-3 py-1 bg-gray-700/50 text-gray-300 text-sm rounded-full border border-gray-600/50 hover:bg-gray-600/50 transition-colors duration-200">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Compétences soft -->
    <div>
      <!-- Label diviseur -->
      <div class="flex items-center justify-center mb-12 reveal">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent to-gray-600"></div>
        <span class="px-6 py-2 bg-gray-800/50 text-gray-300 text-sm font-medium rounded-full border border-gray-600/50">
          Soft Skills
        </span>
        <div class="flex-1 h-px bg-gradient-to-l from-transparent to-gray-600"></div>
      </div>

      <!-- Grille des compétences soft -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {softSkills.map(skill => (
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-lg p-6 hover:bg-white/10 transition-all duration-300 hover:scale-105 group reveal">
            <!-- Icône -->
            <div class="flex items-center justify-center w-12 h-12 bg-gradient-to-br from-purple-500/20 to-pink-500/20 rounded-lg mb-4 group-hover:scale-110 transition-transform duration-200">
              <span set:html={getIcon('User', 'w-6 h-6 text-purple-400')}></span>
            </div>

            <!-- Nom de la compétence -->
            <h3 class="text-xl font-semibold mb-3 text-gray-200">{skill.name}</h3>

            <!-- Description -->
            <p class="text-gray-400 text-sm leading-relaxed">{skill.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
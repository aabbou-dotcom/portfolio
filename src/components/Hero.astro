---
// Hero.astro - Section d'accueil pleine hauteur
// Nom avec dégradé animé, titre, sous-titre, badge de disponibilité,
// photo avec anneau dégradé, boutons d'action, stats, liens sociaux

import { portfolioData } from '../data/data';
import { getIcon } from './icons';

const { personal, stats, socialLinks } = portfolioData;
---

<section id="hero" class="min-h-screen flex items-center justify-center relative px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto text-center">
    <!-- Photo de profil -->
    <div class="mb-8 reveal">
      <div class="relative inline-block">
        <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full bg-gradient-to-br from-blue-500 via-purple-500 to-pink-500 p-1 animate-spin-slow">
          <div class="w-full h-full rounded-full bg-gray-900 flex items-center justify-center overflow-hidden">
            <img
              src={personal.avatar}
              alt={`${personal.firstName} ${personal.lastName}`}
              class="w-full h-full object-cover hover:scale-110 transition-transform duration-500"
            />
          </div>
        </div>
        <!-- Point pulsant de disponibilité -->
        <div class="absolute -bottom-2 -right-2 w-6 h-6 bg-green-500 rounded-full border-4 border-gray-900 animate-pulse">
          <div class="w-full h-full bg-green-400 rounded-full animate-ping"></div>
        </div>
      </div>
    </div>

    <!-- Nom avec dégradé animé -->
    <h1 class="text-4xl sm:text-6xl lg:text-7xl font-bold mb-4 reveal">
      <span class="bg-gradient-to-r from-blue-400 via-purple-500 to-pink-500 bg-clip-text text-transparent animate-gradient">
        {personal.firstName} {personal.lastName}
      </span>
    </h1>

    <!-- Titre et sous-titre -->
    <div class="mb-8 reveal">
      <h2 class="text-xl sm:text-2xl lg:text-3xl text-gray-300 mb-2">{personal.title}</h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto">{personal.subtitle}</p>
    </div>

    <!-- Badge de disponibilité -->
    <div class="mb-8 reveal">
      <span class="inline-flex items-center px-4 py-2 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-sm font-medium">
        <span class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></span>
        Disponible pour des opportunités
      </span>
    </div>

    <!-- Boutons d'action -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12 reveal">
      <a
        href="#projects"
        class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-semibold rounded-lg transition-all duration-200 hover:scale-105 hover:shadow-lg hover:shadow-blue-500/25"
      >
        Voir mes Projets
        <span set:html={getIcon('ChevronDown', 'w-5 h-5 ml-2')}></span>
      </a>
      <button
        id="download-resume"
        class="inline-flex items-center px-8 py-4 bg-white/5 hover:bg-white/10 border border-white/10 text-white font-semibold rounded-lg transition-all duration-200 hover:scale-105 backdrop-blur-sm"
      >
        <span set:html={getIcon('Download', 'w-5 h-5 mr-2')}></span>
        Télécharger CV
      </button>
    </div>

    <!-- Barre de statistiques -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12 reveal">
      {stats.map(stat => (
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-lg p-6 hover:bg-white/10 transition-all duration-200 hover:scale-105">
          <div class="text-2xl sm:text-3xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent mb-2">
            {stat.value}
          </div>
          <div class="text-gray-400 text-sm flex items-center justify-center">
            <span set:html={getIcon(stat.icon, 'w-4 h-4 mr-2')}></span>
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <!-- Liens sociaux -->
    <div class="flex justify-center space-x-4 reveal">
      {socialLinks.map(link => (
        <a
          href={link.url}
          class="w-12 h-12 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 flex items-center justify-center transition-all duration-200 hover:scale-110 hover:border-white/20 group"
          aria-label={link.platform}
        >
          <span set:html={getIcon(link.icon, 'w-6 h-6 group-hover:text-blue-400 transition-colors duration-200')}></span>
        </a>
      ))}
    </div>
  </div>

  <!-- Indicateur de scroll -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce reveal">
    <div class="w-6 h-10 border-2 border-gray-400 rounded-full flex justify-center">
      <div class="w-1 h-3 bg-gray-400 rounded-full mt-2 animate-pulse"></div>
    </div>
  </div>
</section>

<style>
  /* Animation du dégradé */
  @keyframes gradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .animate-gradient {
    background-size: 200% 200%;
    animation: gradient 3s ease infinite;
  }

  /* Rotation lente pour l'anneau */
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin-slow {
    animation: spin-slow 8s linear infinite;
  }
</style>

<script>
  // Gestion du bouton Download Resume
  document.getElementById('download-resume')?.addEventListener('click', () => {
    // Dispatch un événement custom pour ouvrir le modal
    const event = new CustomEvent('open-resume-modal');
    document.dispatchEvent(event);
  });
</script>
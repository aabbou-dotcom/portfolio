---
/**
 * Header.astro
 * Sticky navigation header with theme toggle and mobile hamburger menu
 */

import { getActiveNavItems, portfolioData } from '../data/portfolio';

const navItems = getActiveNavItems();
---

<header class="fixed top-0 left-0 right-0 z-40 transition-all duration-300 py-4 px-4 md:px-8">
  <div class="glass rounded-xl max-w-6xl mx-auto flex items-center justify-between h-16 px-6">
    <!-- Logo / Brand -->
    <a href="#" class="flex items-center gap-2 text-xl font-bold gradient-text hover:opacity-80 transition-opacity">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="hidden sm:inline">{portfolioData.personal.firstName}</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <a
          href={`#${item.id}`}
          class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors duration-300 relative group"
        >
          {item.label}
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] group-hover:w-full transition-all duration-300"></span>
        </a>
      ))}
    </nav>

    <!-- Right Actions -->
    <div class="flex items-center gap-4">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="p-2 rounded-lg hover:bg-white/10 transition-colors"
        aria-label="Toggle theme"
        title="Toggle dark/light mode"
      >
        <svg class="sun-icon w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="moon-icon hidden w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Mobile Menu Toggle -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 rounded-lg hover:bg-white/10 transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="menu-icon w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="close-icon hidden w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Drawer -->
  <div id="mobile-menu" class="hidden fixed inset-0 md:hidden mt-20 z-30">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    
    <!-- Menu Content -->
    <div class="relative ml-auto w-full max-w-xs h-screen glass rounded-l-2xl overflow-y-auto flex flex-col">
      <nav class="flex-1 p-6 space-y-4">
        {navItems.map((item) => (
          <a
            href={`#${item.id}`}
            class="block px-4 py-3 rounded-lg text-[var(--text-primary)] hover:bg-white/10 transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>
      
      <!-- Mobile Theme Toggle in Drawer -->
      <div class="p-6 border-t border-[var(--color-border)]">
        <button
          id="mobile-theme-toggle"
          class="w-full px-4 py-2 rounded-lg bg-white/10 text-[var(--text-primary)] hover:bg-white/20 transition-colors flex items-center justify-center gap-2"
        >
          <span class="sun-icon-mobile">☀️</span>
          <span class="moon-icon-mobile hidden">🌙</span>
          <span id="theme-label">Mode Clair</span>
        </button>
      </div>

      <!-- Social Links in Drawer -->
      <div class="p-6 border-t border-[var(--color-border)] space-y-2">
        {portfolioData.social.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="block px-4 py-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--color-primary)] hover:bg-white/10 transition-colors text-sm"
          >
            {social.platform}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<script is:inline>
  // Theme Toggle
  function setupTheme() {
    const toggle = document.getElementById('theme-toggle');
    const mobileToggle = document.getElementById('mobile-theme-toggle');
    const htmlEl = document.documentElement;
    
    function applyTheme(theme) {
      htmlEl.setAttribute('data-theme', theme);
      htmlEl.style.colorScheme = theme;
      localStorage.setItem('theme', theme);
      
      // Update toggle icons
      const sunIcon = toggle.querySelector('.sun-icon');
      const moonIcon = toggle.querySelector('.moon-icon');
      const mobileSun = mobileToggle?.querySelector('.sun-icon-mobile');
      const mobileMoon = mobileToggle?.querySelector('.moon-icon-mobile');
      const themeLabel = document.getElementById('theme-label');
      
      if (theme === 'dark') {
        sunIcon.classList.add('hidden');
        moonIcon.classList.remove('hidden');
        if (mobileSun) mobileSun.classList.add('hidden');
        if (mobileMoon) mobileMoon.classList.remove('hidden');
        if (themeLabel) themeLabel.textContent = 'Mode Sombre';
      } else {
        sunIcon.classList.remove('hidden');
        moonIcon.classList.add('hidden');
        if (mobileSun) mobileSun.classList.remove('hidden');
        if (mobileMoon) mobileMoon.classList.add('hidden');
        if (themeLabel) themeLabel.textContent = 'Mode Clair';
      }
    }
    
    const currentTheme = htmlEl.getAttribute('data-theme') || 'dark';
    applyTheme(currentTheme);
    
    toggle.addEventListener('click', () => {
      const theme = htmlEl.getAttribute('data-theme');
      const newTheme = theme === 'dark' ? 'light' : 'dark';
      applyTheme(newTheme);
    });
    
    if (mobileToggle) {
      mobileToggle.addEventListener('click', () => {
        const theme = htmlEl.getAttribute('data-theme');
        const newTheme = theme === 'dark' ? 'light' : 'dark';
        applyTheme(newTheme);
      });
    }
  }

  // Mobile Menu Toggle
  function setupMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = toggle.querySelector('.menu-icon');
    const closeIcon = toggle.querySelector('.close-icon');
    const backdrop = menu.querySelector('.absolute.inset-0');
    
    function closeMenu() {
      menu.classList.add('hidden');
      menuIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    
    function openMenu() {
      menu.classList.remove('hidden');
      menuIcon.classList.add('hidden');
      closeIcon.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    
    toggle.addEventListener('click', () => {
      if (menu.classList.contains('hidden')) {
        openMenu();
      } else {
        closeMenu();
      }
    });
    
    backdrop.addEventListener('click', closeMenu);
    
    // Close menu on link click
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
    
    // Close menu on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
        closeMenu();
      }
    });
  }

  // Active Link Highlighting with IntersectionObserver
  function setupActiveLinks() {
    const sections = document.querySelectorAll('[id][data-section]');
    const navLinks = document.querySelectorAll('a[href^="#"]');
    
    const observerOptions = {
      threshold: 0.3,
      rootMargin: '-80px 0px -66% 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          navLinks.forEach(link => {
            link.classList.remove('text-[var(--color-primary)]');
            link.classList.add('text-[var(--text-secondary)]');
          });
          const activeLink = document.querySelector(`a[href="#${id}"]`);
          if (activeLink) {
            activeLink.classList.add('text-[var(--color-primary)]');
            activeLink.classList.remove('text-[var(--text-secondary)]');
          }
        }
      });
    }, observerOptions);
    
    sections.forEach(section => observer.observe(section));
  }

  // Initialize on load
  document.addEventListener('DOMContentLoaded', () => {
    setupTheme();
    setupMobileMenu();
    setupActiveLinks();
  });

  // Also run on initial load for theme
  setupTheme();
</script>

<style>
  /* Subtle header shrink on scroll */
  header {
    transition: padding 0.3s ease;
  }
</style>

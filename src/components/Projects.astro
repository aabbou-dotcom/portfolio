---
/**
 * Projects.astro
 * Portfolio projects showcase with cards
 */

import { portfolioData } from '../data/portfolio';

const projects = portfolioData.projects;
---

<section id="projects" data-section class="py-20 md:py-32 bg-[var(--bg-secondary)]/50">
  <div class="container max-w-6xl mx-auto px-4 md:px-8">
    <!-- Section Title -->
    <div class="mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Mes <span class="gradient-text">Projets</span>
      </h2>
      <p class="text-lg text-[var(--text-secondary)] max-w-2xl">
        Une sélection de mes projets académiques, personnels et professionnels.
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 gap-8">
      {projects.map((project, index) => (
        <div
          data-animate
          class="group relative glass rounded-lg overflow-hidden hover:bg-white/15 hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
          style={`animation-delay: ${index * 100}ms;`}
        >
          <!-- Watermark Number -->
          <div class="absolute -top-8 -right-8 text-7xl font-bold gradient-text opacity-20 pointer-events-none">
            {String(index + 1).padStart(2, '0')}
          </div>

          <!-- Top Gradient Bar (appears on hover) -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>

          <!-- Content -->
          <div class="p-6 md:p-8 relative z-10">
            <!-- Title with Link -->
            <h3 class="text-xl md:text-2xl font-bold mb-3 group-hover:text-[var(--color-primary)] transition-colors duration-300">
              {project.url ? (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 hover:underline"
                >
                  {project.title}
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/>
                  </svg>
                </a>
              ) : (
                project.title
              )}
            </h3>

            <!-- Description -->
            <p class="text-[var(--text-secondary)] mb-6 leading-relaxed">
              {project.description}
            </p>

            <!-- Technologies -->
            <div class="flex flex-wrap gap-2 mb-6">
              {project.technologies.map((tech) => (
                <span class="text-xs px-3 py-1 rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] hover:bg-[var(--color-primary)]/20 transition-colors duration-300">
                  {tech}
                </span>
              ))}
            </div>

            <!-- View Project Button -->
            <div class="flex gap-3">
              {project.url && (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-4 py-2 rounded-lg bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] text-white text-sm font-medium hover:shadow-lg transition-all duration-300 flex items-center gap-2 group/btn"
                >
                  Voir le Projet
                  <svg class="w-4 h-4 group-hover/btn:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              )}
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-4 py-2 rounded-lg glass text-[var(--text-secondary)] text-sm font-medium hover:text-[var(--color-primary)] hover:bg-white/20 transition-all duration-300"
                >
                  Code
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: no-preference) {
    [data-animate] {
      opacity: 0;
      animation: fadeInUp 0.6s ease-out forwards;
    }
  }
</style>

---
/**
 * Certifications.astro
 * Certifications and online courses section (conditional)
 */

import { portfolioData } from '../data/portfolio';

const certifications = portfolioData.certifications || [];

// Group certifications by issuer
const groupedCerts: Record<string, typeof certifications> = {};
certifications.forEach(cert => {
  const issuer = cert.issuer || 'Other';
  if (!groupedCerts[issuer]) {
    groupedCerts[issuer] = [];
  }
  groupedCerts[issuer].push(cert);
});

const issuerOrder = ['Udemy', 'Coursera', 'freeCodeCamp', 'AWS', 'Google', 'Microsoft', 'Elsevier'];
const sortedIssuers = Object.keys(groupedCerts).sort((a, b) => {
  const indexA = issuerOrder.indexOf(a);
  const indexB = issuerOrder.indexOf(b);
  if (indexA === -1 && indexB === -1) return 0;
  if (indexA === -1) return 1;
  if (indexB === -1) return -1;
  return indexA - indexB;
});
---

<section id="certifications" data-section class="py-20 md:py-32">
  <div class="container max-w-6xl mx-auto px-4 md:px-8">
    <!-- Section Title -->
    <div class="mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Formations & <span class="gradient-text">Certifications</span>
      </h2>
      <p class="text-lg text-[var(--text-secondary)] max-w-2xl">
        Mes certifications professionnelles et formations en ligne suivies.
      </p>
    </div>

    <!-- Stats Bar -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-12">
      <div class="glass rounded-lg p-4 text-center">
        <div class="text-2xl md:text-3xl font-bold gradient-text mb-2">{certifications.length}+</div>
        <p class="text-sm text-[var(--text-secondary)]">Certificats</p>
      </div>
      <div class="glass rounded-lg p-4 text-center">
        <div class="text-2xl md:text-3xl font-bold gradient-text mb-2">{sortedIssuers.length}</div>
        <p class="text-sm text-[var(--text-secondary)]">Plateformes</p>
      </div>
      <div class="glass rounded-lg p-4 text-center col-span-2 md:col-span-1">
        <div class="text-2xl md:text-3xl font-bold gradient-text mb-2">{Math.ceil(certifications.length / 4)}</div>
        <p class="text-sm text-[var(--text-secondary)]">Domaines</p>
      </div>
    </div>

    <!-- Certifications by Issuer -->
    <div class="space-y-12">
      {sortedIssuers.map((issuer, issuerIndex) => {
        const issuerCerts = groupedCerts[issuer];
        return (
          <div
            data-animate
            style={`animation-delay: ${issuerIndex * 100}ms;`}
          >
            <!-- Issuer Header -->
            <div class="flex items-center gap-4 mb-6">
              <h3 class="text-2xl font-bold">{issuer}</h3>
              <div class="flex-1 h-px bg-gradient-to-r from-[var(--color-primary)] to-transparent"></div>
              <span class="text-xs font-bold px-3 py-1 rounded-full bg-[var(--color-primary)]/20 text-[var(--color-primary)]">
                {issuerCerts.length}
              </span>
            </div>

            <!-- Certifications Grid -->
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {issuerCerts.map((cert, index) => (
                <div
                  class="group glass rounded-lg p-6 hover:bg-white/15 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
                  style={`animation-delay: ${(issuerIndex * 100) + (index * 50)}ms;`}
                >
                  <!-- Header with date -->
                  <div class="flex items-start justify-between mb-4">
                    <span class="text-xs font-mono px-2 py-1 rounded-full bg-[var(--color-border)]/20 text-[var(--text-secondary)]">
                      {cert.date}
                    </span>
                  </div>

                  <!-- Certificate Name -->
                  <h4 class="font-bold mb-2 line-clamp-2 group-hover:text-[var(--color-primary)] transition-colors duration-300">
                    {cert.name}
                  </h4>

                  <!-- Issuer -->
                  <p class="text-sm text-[var(--text-secondary)] mb-4">{cert.issuer}</p>

                  <!-- Skills -->
                  {cert.skills && cert.skills.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-4">
                      {cert.skills.map((skill) => (
                        <span class="text-xs px-2 py-1 rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)]">
                          {skill}
                        </span>
                      ))}
                    </div>
                  )}

                  <!-- View Link -->
                  {cert.credentialUrl && (
                    <a
                      href={cert.credentialUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs text-[var(--color-primary)] hover:underline font-semibold"
                    >
                      Voir le certificat →
                    </a>
                  )}
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: no-preference) {
    [data-animate] {
      opacity: 0;
      animation: fadeInUp 0.6s ease-out forwards;
    }
  }
</style>
